@page
@model Rockaway.WebApp.Pages.VenuesModel

@{
    ViewData["Title"] = "Venues";
}

<h1>Venues</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].Slug)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].Address)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].City)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].CountryCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].PostalCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].Telephone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue[0].WebsiteUrl)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Venue) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Slug)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.City)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CountryCode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PostalCode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telephone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WebsiteUrl)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
